# SQLite (dados de maré da API)
DB_SQLITE_PATH=/app/data/taubinha.sqlite

# PostgreSQL externo (auth/dash/contadores/credits)
# As vars reais do Postgres externo vem do env do sistema/hospedeiro (nao deste arquivo).
# Este arquivo e' apenas referencia.
#
# Alternativa: em vez das vars DB_* individuais, pode-se usar uma connection string
# completa em POSTGRESQL_CONN_STR (tem precedencia sobre as vars DB_* quando presente).
# Ex: postgresql://user:pass@host:port/dbname
POSTGRESQL_CONN_STR=
DB_DATABASE=
DB_USER=
DB_HOST=
DB_PASS=
DB_PORT=5432

# Google OAuth
GOOGLE_CLIENT_ID=[PRECISA PREENCHER]
GOOGLE_CLIENT_SECRET=[PRECISA PREENCHER]
GOOGLE_REDIRECT_URI=https://tabuamare.api.br/auth/google/callback
GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo
GOOGLE_SCOPE=openid email profile

# Session (JWT HS256)
SESSION_SECRET=[PRECISA PREENCHER - 32+ bytes aleatorios]
SESSION_COOKIE_NAME=tm_session
SESSION_TTL_HOURS=720

# Avatar cache (minutos)
AVATAR_CACHE_TTL_MINUTES=60

# Rate limit (por minuto)
RATE_LIMIT_FREE_RPM=64
RATE_LIMIT_PLAN5_RPM=512
RATE_LIMIT_PLAN10_RPM=2048
RATE_LIMIT_ANON_RPM=16

# Rate limit (por mes; 0 = ilimitado)
RATE_LIMIT_FREE_MONTHLY=32000
RATE_LIMIT_PLAN5_MONTHLY=256000
RATE_LIMIT_PLAN10_MONTHLY=0
RATE_LIMIT_ANON_MONTHLY=0

# Stripe (pagamentos/assinaturas)
# STRIPE_SECRET_KEY: chave secreta da conta Stripe (test ou live).
# STRIPE_WEBHOOK_SECRET: secret do endpoint de webhook configurado no Stripe Dashboard.
#   Cadastrar webhook em: https://dashboard.stripe.com/webhooks
#   Endpoints sugeridos:
#     - Producao: https://tabuamare.api.br/auth/webhook
#     - Localhost (via Stripe CLI ou ngrok): http://localhost:3330/auth/webhook
#   Eventos obrigatorios:
#     - checkout.session.completed
#     - customer.subscription.created
#     - customer.subscription.updated
#     - customer.subscription.deleted
#     - invoice.payment_failed
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PLAN5=
STRIPE_PRICE_PLAN10=
STRIPE_PRICE_PLANANNUAL=
# Timeout (ms) e retries das chamadas à API do Stripe.
# Defaults conservadores (8000ms / 1 retry) para evitar 524 do Cloudflare
# no /auth/checkout, que faz 2 chamadas sequenciais (list_customers +
# create_checkout_session). Pior caso: ~16-18s, bem abaixo do limite CF.
STRIPE_TIMEOUT_MS=8000
STRIPE_MAX_RETRIES=1

# Outros
NEW_RELIC_KEY=
URL_ENV=https://tabuamare.api.br
